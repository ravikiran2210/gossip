{
  "name": "messenger-web",
  "version": "1.0.0",
  "private": true,
  "description": "Admin-gated realtime messenger — web-first monorepo",
  "scripts": {
    "dev:backend": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "build:backend": "pnpm --filter backend build",
    "build:web": "pnpm --filter web build",
    "build": "pnpm run build:backend && pnpm run build:web",
    "lint": "pnpm -r lint",
    "test:backend": "pnpm --filter backend test"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "next": "14.2.3"
  }
}
